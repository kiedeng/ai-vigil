APP_NAME="AI Eye Monitor"
API_PREFIX="/api"

# SQLite by default. For MySQL:
# DATABASE_URL="mysql+pymysql://ai_eye:password@127.0.0.1:3306/ai_eye?charset=utf8mb4"
DATABASE_URL="sqlite:///./data/ai_eye.db"

ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRE_MINUTES=720

NEW_API_BASE_URL="http://localhost:3000"
NEW_API_KEY=""
EVALUATOR_MODEL="deepseek-chat"

DEFAULT_INTERVAL_SECONDS=300
DEFAULT_TIMEOUT_SECONDS=30
DEFAULT_FAILURE_THRESHOLD=3
ALERT_COOLDOWN_MINUTES=30
SCHEDULER_POLL_SECONDS=30
